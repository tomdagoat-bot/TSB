OnEvent.Bind("CharacterAdded",function(char : Model)
	local _,Hum,Hrp,plr,Animator = Things(char)

	task.wait(0.2)

	if _G.TargetName == char.Name then
		SetTarget(char)
	end

	ConnectionService.Connect("Died",char,Hum.Died,nil,"Once",function()
		if _G.Target == char then
			SetTarget(nil,char.Name)
		end
		ConnectionService.Disconnect(nil,char)
	end)

	local CounterDisplay = CounterUI:Clone()
	CounterDisplay.Parent = Hrp

	ConnectionService.Connect("AnimPlayed",char,Animator.AnimationPlayed,nil,"Connect",function(Track)
		local Animation = Track.Animation
		local ID = Animation.AnimationId

		if AnimIDS["Counters"][ID] then
			local ActualCounter = false

			for _, c in char:GetChildren() do
				if c.Name:find("Counter") and c.Name ~= "Counter" then
					ActualCounter = true
					break
				end
			end

			if not ActualCounter then print(char.Name,"is exploiting btw") return end

			local Duration = Track.Length - 0.6
			OnEvent.Fire("Counter",char,Hrp,Duration,CounterDisplay)
		elseif AnimIDS["SideDash"][ID] then
			if not char:GetAttribute("Ragdolled_") then return end

			DelayService.CountDown(char.Name.."-Evasive",30,1,function(elapsed)
				char:SetAttribute("Evasive", elapsed)
			end,function()
				char:SetAttribute("Evasive", nil)
			end)
		end
	end)

	ConnectionService.Connect("ChildAdded",char,char.ChildAdded,nil,"Connect",function(r)
		if r.Name == "Ragdoll" or r.Name == "RagdollSim" then
			char:SetAttribute("Ragdolled_", true)
		elseif r.Name == "Counter" and (char:FindFirstChild("Death Counter") or plr and plr.Backpack:FindFirstChild("Death Counter")) then 
			OnEvent.Fire("Death Counter",char,Hrp,CounterDisplay)
		end
	end)

	ConnectionService.Connect("UnRagdolled",char,char.ChildRemoved,nil,"Connect",function(r)
		if r.Name == "Ragdoll" or r.Name == "RagdollSim" then
			DelayService.Delay(char.Name.."-Unragdoll",0.2,function()
				char:SetAttribute("Ragdolled_", false)
			end)
		end
	end)
end)

