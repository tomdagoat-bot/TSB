function StareAtOpposite(Root,Hrp,Duration)
	--[[ Root : Our HumanoidRootPart, Hrp : Their HumanoidRootPart ]]
	if Root == Hrp then
		return
	end
	local char = Root.Parent
	ConnectionService.Connect("Near",char,RunService.PreRender,Duration,"Connect",function()
		if MathService.GetDistance(Root,Hrp) <= 20 then
			StopStare()
			MathService.LookAt(Root, Root.Position * 2 - Hrp.Position)
		else
			SilentAim()
		end
	end)

	DelayService.Delay(Hrp.Parent.Name.."-CounteredStare",Duration + 0.2,function()
		SilentAim()
	end)
end

OnEvent.new("Counter")

OnEvent.Bind("Counter",function(char,Hrp,Duration,CounterDisplay)
	local _,_,Root,_ = Me()

	local Distance = MathService.GetDistance(Root,Hrp)

	if Distance <= 20 then
		PlaySound("Counter")
		if Distance <= 10 then
			Communicate({Dash = Enum.KeyCode.S, Key = Enum.KeyCode.Q, Goal = "KeyPress"})
			Root.AssemblyLinearVelocity = -Hrp.CFrame.LookVector * 90
		end
	end

	HighlightService.new("Counter",char,Duration)

	if CounterDisplay then
		CounterDisplay.Counter.Visible = true

		DelayService.Delay(char.Name.."-Counter",Duration,function()
			CounterDisplay.Counter.Visible = false
		end)
	end

	StareAtOpposite(Root,Hrp,Duration)
end)

