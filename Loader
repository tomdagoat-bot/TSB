	TargetUI.Username.Text = TargetPlayer and TargetPlayer.DisplayName or Target.Name
	TargetUI.Username.Profile:FindFirstChildOfClass("ImageLabel").Image = GetProfile(TargetPlayer)

	if TargetPlayer then

		Evasive(Target)

		ConnectionService.Connect("Evasive","Target",Target:GetAttributeChangedSignal("Evasive"),nil,"Connect",function()
			Evasive(Target)
		end)

		Kills(TargetPlayer)

		ConnectionService.Connect("KillsAdded","Target",TargetPlayer:WaitForChild("leaderstats").ChildAdded,nil,"Connect",function(DataStored)
			if DataStored.Name == "Kills" then
				Kills(TargetPlayer)
			end
		end)

		ConnectionService.Connect("KillsRemoved","Target",TargetPlayer:WaitForChild("leaderstats").ChildRemoved,nil,"Connect",function(DataStored)
			if DataStored.Name == "Kills" then
				Kills(TargetPlayer)
			end
		end)

		DeathCounter(Target)

		ConnectionService.Connect("DeathCountered","Target",Target:GetAttributeChangedSignal("DC_"),nil,"Connect",function()
			DeathCounter(Target)
		end)

		TotalKills(TargetPlayer)

		ConnectionService.Connect("Total Kills","Target",TargetPlayer:GetAttributeChangedSignal("TotalKillsFrb"),nil,"Connect",function()
			TotalKills(TargetPlayer)
		end)

		Streak(Target)

		ConnectionService.Connect("Streak","Target",Target:GetAttributeChangedSignal("CurrentStreak"),nil,"Connect",function()
			Streak(Target)
		end)

		Ultimate(TargetPlayer)

		ConnectionService.Connect("Ultimate","Target",TargetPlayer:GetAttributeChangedSignal("Ultimate"),nil,"Connect",function()
			Ultimate(TargetPlayer)
		end)

		TargetUI.Moveset.Text = "Moveset: "..MovesetTranslation[Target:GetAttribute("Character") or "CUSTOM"]

		ConnectionService.Connect("Moveset","Target",Target:GetAttributeChangedSignal("Character"),nil,"Connect",function()
			TargetUI.Moveset.Text = "Moveset: "..MovesetTranslation[Target:GetAttribute("Character") or "CUSTOM"]
		end)
	end

	TargetBars.Ragdoll.Visible = TargetPlayer ~= nil
	TargetBars.Ultimate.Visible = TargetPlayer ~= nil
	TargetUI.Moveset.Visible = TargetPlayer ~= nil
	TargetUI.Kills.Visible = TargetPlayer ~= nil
