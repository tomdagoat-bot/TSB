local function PredictCFrame(hrp, t)
    local Pos = hrp.Position + hrp.AssemblyLinearVelocity * t
    return CFrame.new(Pos, Pos + hrp.CFrame.LookVector)
end

local function StareConnection(Object)
	if not _G.Target and not Object then warn("Please Select A Target.") return end
	local Hum = _G.Target and _G.Target:FindFirstChild("Humanoid")

	if not Hum or Hum.Health <= 0 then
		return
	end

	local Char, MyHum, Hrp = Me()
	
	if not Char or not MyHum or not Hrp or MyHum.Health <= 0 then
		return
	end

	local Goal = Object or _G.Target:WaitForChild("HumanoidRootPart")

	DelayService.Yield(function()
		return not Char:FindFirstChild("Ragdoll") or not Char:FindFirstChild("RagdollSim")
	end,20)

	ConnectionService.Connect("Stare",Char,RunService.PreRender,nil,"Connect",function()
		if UserInputService.MouseBehavior == Enum.MouseBehavior.LockCenter then return end
		local Where = _G.PredictionEnabled and PredictCFrame(Goal,_G.Prediction) or Goal
		MathService.LookAt(Hrp,Where,_G.Lerp)
	end)
end

