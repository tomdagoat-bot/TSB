local LocalHealth = UI.Health

function Off(Duration)
	StopStare()

	DelayService.Cancel("On")

	DelayService.Delay("Off",Duration,function()
		SilentAim()
	end)
end

function On(Duration,Object)
	StopStare()
	StareConnection(Object)

	DelayService.Cancel("Off")

	DelayService.Delay("On",Duration,function()
		SilentAim()
	end)
end

function OnCD(Skill,CD)
	local Frame = UI.Cooldowns:FindFirstChild(Skill, true)
	if not Frame then
		return
	end

	local Fill = Frame.Fill
	local Value = Frame:FindFirstChildOfClass("TextLabel")

	Fill.Size = UDim2.fromScale(1, 1)
	TweenService:Create(Fill,TweenInfo.new(CD, Enum.EasingStyle.Linear, Enum.EasingDirection.In),{Size = UDim2.fromScale(0, 1)}):Play()

	DelayService.CountDown(Skill,CD,1,function(elapsed)
		Value.Text = Skill..": "..tostring(elapsed)
	end,function()
		Value.Text = Skill
	end)
end

local function CanDash(Compare)
	return tick() - _G.LastDash > (Compare or 5)
end

local function MoveOnCD(Move)
	local HotBar = PlayerGui.Hotbar.Backpack.Hotbar
	local Frame
	for _, Object in HotBar:QueryDescendants("TextLabel") do
		if Object.Text:find(Move) then
			Frame = Object.Parent
			break
		end
	end

	if not Frame then return true end
	local CD = Frame:FindFirstChild("Cooldown")

	return CD ~= nil
end

_G.LastDash = 0

local ColorShift = TweenInfo.new(0.6,Enum.EasingStyle.Linear,Enum.EasingDirection.In)
local RNG = Random.new()

OnEvent.Bind("MyCharacterAdded",function(char)
	local _,Hum,Hrp,Anim = Me()

	char:SetAttribute("UltimateName","GERP HUB")

	ConnectionService.Connect("UltName",char,char:GetAttributeChangedSignal("UltimateName"),nil,"Connect",function() 
		if char:GetAttribute("UltimateName") == "GERP HUB" then return end
		char:SetAttribute("UltimateName","GERP HUB")
	end)

	local TechEffect = TechDisplay:Clone()
	TechEffect.Parent = char

	local UltimateUI = PlayerGui:WaitForChild("Bar")
	local UltHolder = UltimateUI.MagicHealth.Health

	local UltimateBar = UltHolder.Bar.Bar

	TweenService:Create(UltimateBar,ColorShift,{ImageColor3 = Color3.fromRGB(0, 0, 255)}):Play()

	task.wait(0.2)

	for _, CD in UI.Cooldowns:GetDescendants() do
		if CD.Name:find("Dash") or CD.Name == "Evasive" then
			local label = CD:FindFirstChildOfClass("TextLabel")
			if not label then continue end

			label.Text = CD.Name
		end
	end

	SilentAim()

	ConnectionService.Connect("Ragdolled",char,char.ChildAdded,nil,"Connect",function(r)
		if r.Name == "Ragdoll" or r.Name == "RagdollSim" then
			char:SetAttribute("Ragdolled_", true)
			StopStare()
		end
	end)

	ConnectionService.Connect("UnRagdolled",char,char.ChildRemoved,nil,"Connect",function(r)
		if r.Name == "Ragdoll" or r.Name == "RagdollSim" then
			DelayService.Delay(char.Name.."-Unragdoll",0.2,function()
				char:SetAttribute("Ragdolled_", false)
			end)
			SilentAim()
		end
	end)

	local alpha = MathService.Alpha(Hum.Health,Hum.MaxHealth)
	TweenService:Create(LocalHealth.Fill,Bar,{Size = UDim2.fromScale(alpha,1)}):Play()
	LocalHealth:FindFirstChildOfClass("TextLabel").Text = tostring(math.round(alpha * 100)).."%"

	ConnectionService.Connect("Health",char,Hum.HealthChanged,nil,"Connect",function()
		alpha = MathService.Alpha(Hum.Health,Hum.MaxHealth)
		TweenService:Create(LocalHealth.Fill,Bar,{Size = UDim2.fromScale(alpha,1)}):Play()
		LocalHealth:FindFirstChildOfClass("TextLabel").Text = tostring(math.round(alpha * 100)).."%"

		if alpha <= 0 then
			ConnectionService.Disconnect(nil,char)
			if RNG:NextInteger(0,5) == 0 then
				PlaySound("Skill-Issue")
			end
		end
	end)

	ConnectionService.Connect("Died",char,Hum.Died,nil,"Once",function()
		ConnectionService.Disconnect(nil,char)
	end)

	ConnectionService.Connect("Animation",char,Anim.AnimationPlayed,nil,"Connect",function(Track : AnimationTrack)
		local Animation = Track.Animation
		local ID = Animation.AnimationId

		local Success = false
		local Condition

		for AnimName, AnimArray in AnimIDS do
			if AnimArray[ID] then
				Success = true
				Condition = AnimName
				break
			end
		end

		if not Success then return end

		if Condition == "FrontDash" then
			_G.LastDash = tick()
			OnCD("Front Dash",5)
		elseif Condition == "SideDash" then
			if char:GetAttribute("Ragdolled_") then
				OnCD("Evasive",30)
			end
			OnCD("Side Dash",2)
		elseif Condition == "Lethal" then
			Off(Track.Length)
		end

		local Nearest = GetNearest(Hrp)
		if not Nearest then return end

		local _,TargetHum,Origin,TargetPlayer,_ = Things(Nearest)

		local ChoosenTech
		local LastPriority = -1

		for _, Tech in pairs(TechService.Techs["Animations"]) do
			if not Tech.Enabled then
				continue
			end

			if Tech.Animation ~= Condition then
				continue
			end

			if Tech.RequiresPlayer and not TargetPlayer then
				continue
			end

			if Tech.UsesSkill and MoveOnCD(Tech.Skill) then
				continue
			end

			if Tech.Priority > LastPriority then
				LastPriority = Tech.Priority
				ChoosenTech = Tech
			end
		end

		if not ChoosenTech then return end

		if ChoosenTech.RequiresTarget then
			if MathService.GetDistance(Hrp,Origin) > 8 or TargetHum.Health <= 3 then return end

			if Condition == "Uppercut" or Condition == "Forth" then
				if UserInputService.MouseBehavior == Enum.MouseBehavior.LockCenter then return end
				if not CanDash(5 - 0.433) then return end
				ConnectionService.Connect(ChoosenTech.Name,char,Track:GetMarkerReachedSignal(ChoosenTech.Marker),Track.Length + 1,"Connect",function()
					if ChoosenTech.Marker == "swingreg" then
						task.wait(Condition == "Uppercut" and 0.11 or 0.07)
					end
					task.spawn(UsedTech,ChoosenTech.Name,char)
					ChoosenTech.MarkerReached(Origin,Hrp,Track)
				end)
			elseif Condition == "Lethal" then
				if not CanDash(5 - Track.Length) then return end
				Off(Track.Length)
				ConnectionService.Connect("Lethal",char,Track:GetMarkerReachedSignal(ChoosenTech.Marker),Track.Length + 1,"Connect",function()
					if UserInputService.MouseBehavior == Enum.MouseBehavior.LockCenter then return end
					if TargetHum.Health <= 15 then return end
					task.spawn(UsedTech,ChoosenTech.Name,char)
					ChoosenTech.MarkerReached(Origin,Hrp,Track)
				end)
			end
		end

		if ChoosenTech.OnPlayed then
			ChoosenTech.OnPlayed(Origin,Hrp,Track)
		end
	end)

end)

