local function Evasive(Target)
	if Target:GetAttribute("JustEvasived") then
		local endtime = Target:GetAttribute("JustEvasived") + 30
		if endtime - tick() <= 0 then
			TargetBars.Ragdoll.Visible = false
		else
			TargetBars.Ragdoll.Visible = true
		
			local timeleft = endtime - tick()
		
			local alpha = MathService.Alpha(timeleft,30)
		
			DelayService.CountDown("Targetation-Evasivation",timeleft,1,function(elapsed)
				TargetBars.Ragdoll.Value.Text = "Evasive: "..tostring(math.floor(elapsed)).."s"
			end,function()
				TargetBars.Ragdoll.Visible = false
			end)
		
			TweenService:Create(TargetBars.Ragdoll.Fill,Bar,{Size = UDim2.fromScale(alpha,1)}):Play()
			task.wait(Bar.Time)
			TweenService:Create(TargetBars.Ragdoll.Fill,TweenInfo.new(timeleft - Bar.Time,Enum.EasingStyle.Linear,Enum.EasingDirection.In),{Size = UDim2.fromScale(0,1)}):Play()
		end
	else
		TargetBars.Ragdoll.Visible = false
	end
end

