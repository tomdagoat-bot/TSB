	DelayService.Yield(function() return not Target:FindFirstChildOfClass("ForceField") end,20)
	if Target:GetAttribute("UltimateTime") then
		local endtime = Target:GetAttribute("JustUltimate") + Target:GetAttribute("UltimateTime")
