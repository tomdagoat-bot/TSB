			local alpha = MathService.Alpha(timeleft,Target:GetAttribute("UltimateTime"))
			TweenService:Create(TargetBars.Ultimate.Fill,Bar,{Size = UDim2.fromScale(alpha,1)}):Play()

			DelayService.CountDown("Targetation-Ultimation",timeleft,1,function(elapsed)
				TargetBars.Ultimate.Value.Text = "Ultimate: "..tostring(math.floor(elapsed)).."s"
				alpha = MathService.Alpha(elapsed,Target:GetAttribute("UltimateTime"))
