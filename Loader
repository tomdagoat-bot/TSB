			end,function()
				TargetBars.Ultimate.Value.Text = "Ultimate: 0%"
			end)
		end
	else
		TargetBars.Ultimate.Value.Text = "IN ULTIMATE"
		TweenService:Create(TargetBars.Ultimate.Fill,Bar,{Size = UDim2.fromScale(1,1)}):Play()
	end
end

function UpdateTarget()
	local Target : Model,TargetHum : Humanoid,TargetRoot,TargetPlayer : Player,_ = Things()

	TargetUI.Username.Text = TargetPlayer and TargetPlayer.DisplayName or Target.Name
	TargetUI.Username.Profile:FindFirstChildOfClass("ImageLabel").Image = GetProfile(TargetPlayer)

	ConnectionService.Disconnect("TargetInUlt",Player)

	TargetBars.Ultimate.Visible = TargetPlayer ~= nil
	TargetBars.Ragdoll.Visible = TargetPlayer ~= nil
	TargetUI.Moveset.Visible = TargetPlayer ~= nil
	TargetUI.Kills.Visible = TargetPlayer ~= nil
	TargetUI["Total Kills"].Visible = TargetPlayer ~= nil
	TargetUI.Streak.Visible = TargetPlayer ~= nil

	if TargetPlayer then

		Evasive(Target)

		ConnectionService.Connect("Evasive","Target",Target:GetAttributeChangedSignal("JustEvasived"),nil,"Connect",function()
			if AttributeUPDATE then return end
			AttributeUPDATE = true
			Target:SetAttribute("JustEvasived",tick())
			AttributeUPDATE = false
			Evasive(Target)
		end)

		Kills(TargetPlayer)

		ConnectionService.Connect("KillsAdded","Target",TargetPlayer:WaitForChild("leaderstats").ChildAdded,nil,"Connect",function(DataStored)
			if DataStored.Name == "Kills" then
				Kills(TargetPlayer)
			end
		end)

		ConnectionService.Connect("KillsRemoved","Target",TargetPlayer:WaitForChild("leaderstats").ChildRemoved,nil,"Connect",function(DataStored)
			if DataStored.Name == "Kills" then
				Kills(TargetPlayer)
			end
		end)

		DeathCounter(Target)

		ConnectionService.Connect("DeathCountered","Target",Target:GetAttributeChangedSignal("DC_"),nil,"Connect",function()
			DeathCounter(Target)
		end)

		TotalKills(TargetPlayer)

		ConnectionService.Connect("Total Kills","Target",TargetPlayer:GetAttributeChangedSignal("TotalKillsFrb"),nil,"Connect",function()
			TotalKills(TargetPlayer)
		end)

		Streak(Target)

		ConnectionService.Connect("Streak","Target",Target:GetAttributeChangedSignal("CurrentStreak"),nil,"Connect",function()
			Streak(Target)
		end)

		Ultimate(TargetPlayer)

		ConnectionService.Connect("Ultimate","Target",TargetPlayer:GetAttributeChangedSignal("Ultimate"),nil,"Connect",function()
			Ultimate(TargetPlayer)
		end)

		if Target:GetAttribute("Ulted") then
			InUlt(Target)
		end

		ConnectionService.Connect("UltimateIn","Target",Target:GetAttributeChangedSignal("Ulted"),nil,"Connect",function()
			if not Target:GetAttribute("Ulted") then return end
			InUlt(Target)
		end)

		TargetUI.Moveset.Text = "Moveset: "..MovesetTranslation[Target:GetAttribute("Character") or "CUSTOM"]

		ConnectionService.Connect("Moveset","Target",Target:GetAttributeChangedSignal("Character"),nil,"Connect",function()
			TargetUI.Moveset.Text = "Moveset: "..MovesetTranslation[Target:GetAttribute("Character") or "CUSTOM"]
		end)
	end

	Health(TargetHum,Target)

	ConnectionService.Connect("Health","Target",TargetHum.HealthChanged,nil,"Connect",function()
		Health(TargetHum,Target)
	end)

	ConnectionService.Connect("Teleportation","Target",Teleporter.MouseButton1Click,nil,"Connect",function()
		local _,_,Root = Me()
		Root.CFrame = TargetRoot.CFrame * CFrame.new(0,0,5)
	end)

end

