function TechAttributes()
	return {
		Name = "Tech",
		Input = "E",
		Signal = "swingreg",
		Condition = "Animation",
		Enabled = false,
		OnEnable = nil,
		OnDisable = nil,
		Display = true,
		Priority = 0,
		DisableOthers = true,
		AutoToggle = true,
		requiresPlayer = false,
		requiresTarget = true,
		MarkerReached = nil, -- animations
		OnPlayed = nil, -- animations
		OnChanged = nil, -- attributes
		ConditionName = "Uppercut",
		UsesSkill = false,
		Skill = nil,
	}
end

TechService.new = function(Attributes : typeof(TechAttributes()))
	local self = setmetatable({}, TechService)
	local Properties = TechAttributes()

	for key, value in pairs(Attributes) do
		Properties[key] = value
	end

	self.Name = Properties.Name
	self.Input = Enum.KeyCode[Properties.Input]
	self.Condition = Properties.Condition
	self.AutoToggle = Properties.AutoToggle

	self.RequiresTarget = Properties.requiresTarget

	self.DisablesOthers = Properties.DisableOthers

	self.Enabled = Properties.Enabled

	self.OnEnable = Properties.OnEnable 
	self.OnDisable = Properties.OnDisable

	self.CD = false
	self.RequiresPlayer = Properties.requiresPlayer

	self.Priority = Properties.Priority
	self.Displays = Properties.Display

	self.UsesSkill = Properties.UsesSkill
	self.Skill = Properties.Skill

	self.Animation = Properties.ConditionName
	self.Marker = Properties.Signal
	self.OnPlayed = Properties.OnPlayed
	self.MarkerReached = Properties.MarkerReached

	OnEvent.new(self.Name)

	OnEvent.Bind(self.Name,function()
		if self.CD then return end -- if true
		self.CD = not self.CD -- not false --> true

		if self.AutoToggle then
			self.Enabled = not self.Enabled
		end

		if self.Enabled and self.OnEnable then
			task.spawn(self.OnEnable)
		elseif not self.Enabled and self.OnDisable then
			task.spawn(self.OnDisable)
		end

		self:UpdateButton()

		if self.DisablesOthers and self.Enabled then
			task.wait(0.15)
			for _, Tech in pairs(TechService.Techs[self.Condition.."s"]) do
				if Tech == self then continue end
				if Tech.Animation ~= self.Animation then continue end
				if Tech.Priority > self.Priority then continue end

				if Tech.Enabled then
					Tech.CD = not Tech.CD
					Tech.Enabled = not Tech.Enabled

					Tech:UpdateButton()

					DelayService.Delay(Tech.Name.."-AutoDisabled",0.5,function()
						Tech.CD = not Tech.CD
					end)
				end
			end
		end

		task.wait(0.5)

		self.CD = not self.CD -- not true --> false

	end)

	Inputs[self.Input] = function()
		self:Toggle()
	end

	if self.Displays then
		local Button = TechButton:Clone()
		Button.Parent = UI.Options
		Button.Text = self.Name..": "..ToggledString(self.Enabled)

		self.Button = Button

		Button.MouseButton1Click:Connect(function()
			self:Toggle()
		end)
	end

	TechService.Techs[self.Condition.."s"][self.Name] = self
	TechService.Storage[self.Name] = self

	Properties = nil

	return self
end

function TechService:Toggle()
	OnEvent.Fire(self.Name)
end

function TechService:UpdateButton()
	if self.Button then
		TweenService:Create(self.Button,PopUp,{Size = UDim2.fromScale(self.Button.Size.X.Scale * 1.2,self.Button.Size.Y.Scale * 1.3)}):Play()
		self.Button.Text = self.Name..": "..ToggledString(self.Enabled)
		PlaySound("Button")
	end
end

