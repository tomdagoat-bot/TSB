function SetTarget(value,name)
	local OldTarget = _G.Target

	if OldTarget and OldTarget:FindFirstChild("Silent") then
		HighlightService.FadeOut(OldTarget:FindFirstChild("Silent"))
	end

	_G.Target = value
	_G.TargetName = name
	if not value then
		TweenService:Create(UI.Target,Appear,{Position = UI.Target:GetAttribute("Hidden")}):Play()
		TargetBars.Health.Fill.Size = UDim2.fromScale(1, 1)
		StopStare()
		ConnectionService.Disconnect(nil,"Target")
	else
		TweenService:Create(UI.Target,Appear,{Position = UI.Target:GetAttribute("Position")}):Play()
		UpdateTarget()
		HighlightService.new("Silent",_G.Target)
		SilentAim()
	end

	PlaySound("Open")
end

